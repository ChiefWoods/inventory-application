{
  "name": "@inventory-application/api",
  "version": "0.0.0",
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "docker:db:up": "docker compose up -d db",
    "docker:db:start": "docker compose start db",
    "docker:db:stop": "docker compose stop db",
    "docker:db:down": "docker compose down",
    "docker:test-db:up": "docker compose -p inventory-test --profile test up -d test-db",
    "docker:test-db:start": "docker compose -p inventory-test start test-db",
    "docker:test-db:stop": "docker compose -p inventory-test stop test-db",
    "docker:test-db:down": "docker compose -p inventory-test --profile test down",
    "docker:test-db:reset": "docker compose -p inventory-test --profile test down -v",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config drizzle.config.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "bunx drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "bun-types": "latest",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9"
  },
  "module": "src/index.js"
}
